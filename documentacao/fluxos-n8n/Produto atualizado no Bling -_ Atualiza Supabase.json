      ],
      "webhookId": "28c0d868-8e83-4d20-8007-05dc93c2d511"
    },
    {
      "parameters": {
        "jsCode": "const result = [];\n\nfor (const item of $input.all()) {\n  const produto = item.json.body?.data || {};\n  \n  const bling_id = produto.id || null;\n  const sku = produto.codigo || null;\n  const product = produto.nome || \"Sem Nome\";\n  \n  let status = produto.situacao;\n  if (status === 'A') status = 'Ativo';\n  else if (status === 'I') status = 'Inativo';\n  else if (status === 'E') status = 'Excluído';\n\n  const type = (produto.unidade || \"\").toUpperCase() || null;\n  \n  const precoBruto = produto.preco; \n  let precoTratado = null;\n\n  if (precoBruto !== null && precoBruto !== undefined && precoBruto !== \"\") {\n    if (typeof precoBruto === 'number') {\n      precoTratado = precoBruto;\n    } else {\n      let cleanPrice = precoBruto.toString().replace(/\\./g, '').replace(',', '.');\n      precoTratado = parseFloat(cleanPrice);\n    }\n  }\n\n  result.push({\n    json: {\n      bling_id: bling_id,\n      sku: sku,\n      product: product,\n      type: type,\n      product_price: precoTratado,\n      status: status,\n      last_updated: new Date().toISOString()\n    }\n  });\n}\n\nreturn result;"
      },
      "id": "1c15615d-2f88-477c-b971-469ab0864f91",
      "name": "Trata Dados",
      "type": "n8n-nodes-base.code",
