    {
      "parameters": {
        "jsCode": "const result = [];\nfor (const item of $input.all()) {\n  const produto = item.json.data || item.json;\n  const fallback = $('Trata Dados').item.json;\n  \n  const precoTratado = parseFloat(produto.preco);\n  \n  let status = produto.situacao || fallback.status;\n  if (status === 'A') status = 'Ativo';\n  else if (status === 'I') status = 'Inativo';\n  else if (status === 'E') status = 'Excluído';\n\n  const type = (produto.unidade || \"\").toUpperCase() || fallback.type;\n\n  result.push({\n    json: {\n      bling_id: produto.id || fallback.bling_id,\n      sku: produto.codigo || fallback.sku,\n      product: produto.nome || fallback.product,\n      type: type,\n      product_price: isNaN(precoTratado) ? 0 : precoTratado,\n      status: status,\n      last_updated: new Date().toISOString()\n    }\n  });\n}\nreturn result;"
      },
