    {
      "parameters": {
        "jsCode": "const contact = $input.item.json.data;\nconst order = $('If4').item.json.data;\n\nconst newOrder = JSON.parse(JSON.stringify(order));\n\nconst contactAddr = contact.endereco?.geral || {};\n\nif (!newOrder.transporte) newOrder.transporte = {};\nif (!newOrder.transporte.etiqueta) newOrder.transporte.etiqueta = {};\n\nnewOrder.transporte.etiqueta.endereco = contactAddr.endereco;\nnewOrder.transporte.etiqueta.numero = contactAddr.numero;\nnewOrder.transporte.etiqueta.complemento = contactAddr.complemento;\nnewOrder.transporte.etiqueta.bairro = contactAddr.bairro;\nnewOrder.transporte.etiqueta.municipio = contactAddr.municipio;\nnewOrder.transporte.etiqueta.uf = contactAddr.uf;\nnewOrder.transporte.etiqueta.cep = contactAddr.cep;\n\nreturn { data: newOrder };"
      },
