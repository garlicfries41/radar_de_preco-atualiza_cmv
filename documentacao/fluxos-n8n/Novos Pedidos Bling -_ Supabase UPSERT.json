    {
      "parameters": {
        "jsCode": "const input = $input.all();\n\n// Tenta obter body_event de forma robusta\nlet body_event = null;\n\n// 1. Tenta do nó gatilho\ntry {\n  const triggerItems = $items(\"When Executed by Another Workflow\");\n  if (triggerItems && triggerItems.length > 0) {\n    body_event = triggerItems[0].json.body_event;\n  }\n} catch (e) {}\n\n// 2. Se falhar, tenta do nó \"If\" (o usuário chamou de If2, mas pelo JSON é \"If\")\nif (!body_event) {\n  try {\n    const ifItems = $items(\"If2\");\n    if (ifItems && ifItems.length > 0) {\n      body_event = ifItems[0].json.body_event;\n    }\n  } catch (e) {}\n}\n\n// 3. Fallback final via seletor $()\nif (!body_event) {\n  try {\n    const triggerNode = $(\"When Executed by Another Workflow\");\n    if (triggerNode) {\n      body_event = triggerNode.first().json.body_event;\n    }\n  } catch (e) {}\n}\n\nreturn input.map(({ json }) => {\n  const d = json.data ?? json;\n\n  const items = (d.itens ?? []).map((it) => {\n    const qty = Number(it.quantidade ?? 0);\n    const unit = Number(it.valor ?? 0);\n    return {\n      quantity: qty,\n      cost_price: 0,\n      product_id: it.produto?.id ?? null,\n      unit_price: unit,\n      description: it.descricao ?? null,\n      total_price: qty * unit,\n      product_code: it.codigo ?? null,\n      item_discount: Number(it.desconto ?? 0),\n    };\n  });\n\n  // Parsing Delivery Date\n  const isValidDate = (s) => typeof s === \"string\" && /^\\d{4}-\\d{2}-\\d{2}$/.test(s) && s !== \"0000-00-00\";\n  const delivery_date = isValidDate(d.dataPrevista) ? d.dataPrevista : null;\n\n  // Parsing Delivery Period (Slot)\n  let slot = String(d.observacoes ?? \"\").trim().toLowerCase();\n  const validSlots = [\"manha\", \"manhã\", \"tarde\", \"noite\", \"feira\"];\n  let delivery_period = validSlots.includes(slot) ? slot : null;\n  \n  if (delivery_period === \"manhã\") delivery_period = \"manha\";\n\n  const etiqueta = d.transporte?.etiqueta ?? {};\n\n  const payload_std = {\n    items,\n    order: {\n      id: d.id ?? null,\n      date: d.data ?? null,\n      status_id: d.situacao?.id ?? null,\n      status_value: d.situacao?.valor ?? null,\n      status_text: d.situacao?.nome ?? null,\n      order_number: d.numero ?? null,\n      store_number: d.numeroLoja ?? null,\n      delivery_date: delivery_date,\n      delivery_period: delivery_period\n    },\n    totals: {\n      shipping: Number(d.transporte?.frete ?? 0),\n      items_total: Number(d.totalProdutos ?? 0),\n      order_total: Number(d.total ?? 0),\n      order_discount: Number(d.desconto?.valor ?? 0),\n      other_expenses: Number(d.outrasDespesas ?? 0),\n    },\n    customer: {\n      id: d.contato?.id ?? null,\n      name: d.contato?.nome ?? null,\n      tax_id: d.contato?.numeroDocumento ?? null,\n      address: {\n        address: etiqueta.endereco ?? null,\n        number: etiqueta.numero ?? null,\n        complement: etiqueta.complemento ?? null,\n        neighborhood: etiqueta.bairro ?? null,\n        city: etiqueta.municipio ?? null,\n        state: etiqueta.uf ?? null,\n        postal_code: etiqueta.cep ?? null,\n      },\n    },\n  };\n\n  return {\n    json: {\n      order_id: String(d.id ?? \"\"),\n      customer_id: String(d.contato?.id ?? \"\"),\n      order_date: d.data ?? null,\n      status_id: d.situacao?.id ?? null,\n      status_value: d.situacao?.valor ?? null,\n      synced_at: new Date().toISOString(),\n      body_event: body_event,\n      payload_raw: d,\n      payload_std: payload_std\n    },\n  };\n});\n"
      },
